<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 52" fill="none">
  <!-- 배경 없음 (투명) -->
  <!-- 왼쪽: 수륙양용버스 아이콘 박스 -->
  <rect x="0" y="4" width="44" height="44" rx="10" fill="#071f4e"/>
  <!-- 버스 차체 -->
  <rect x="6" y="14" width="32" height="18" rx="4" fill="#1e40af"/>
  <!-- 버스 창문 -->
  <rect x="9" y="17" width="9" height="7" rx="2" fill="#93c5fd"/>
  <rect x="21" y="17" width="9" height="7" rx="2" fill="#93c5fd"/>
  <!-- 버스 하단 -->
  <rect x="6" y="29" width="32" height="4" rx="1" fill="#1d4ed8"/>
  <!-- 바퀴 -->
  <circle cx="14" cy="36" r="4" fill="#1e293b"/>
  <circle cx="14" cy="36" r="2" fill="#64748b"/>
  <circle cx="30" cy="36" r="4" fill="#1e293b"/>
  <circle cx="30" cy="36" r="2" fill="#64748b"/>
  <!-- 물결 (수상 구간) -->
  <path d="M4 41 Q10 37 16 41 Q22 45 28 41 Q34 37 40 41" stroke="#06b6d4" stroke-width="2.5" stroke-linecap="round" fill="none"/>
  <path d="M4 45 Q10 41 16 45 Q22 49 28 45 Q34 41 40 45" stroke="#22d3ee" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.6"/>

  <!-- 오른쪽: 브랜드 텍스트 -->
  <!-- Aqua Mobility Korea (메인) -->
  <text x="52" y="24" font-family="'Noto Sans KR', 'Apple SD Gothic Neo', Arial, sans-serif" font-size="15" font-weight="800" fill="#06b6d4" letter-spacing="-0.3">Aqua Mobility Korea</text>
  <!-- 아쿠아모빌리티코리아 (서브) -->
  <text x="52" y="40" font-family="'Noto Sans KR', 'Apple SD Gothic Neo', Arial, sans-serif" font-size="10" font-weight="500" fill="rgba(255,255,255,0.7)" letter-spacing="0.5">아쿠아모빌리티코리아</text>
  <!-- 구분선 -->
  <line x1="52" y1="28" x2="196" y2="28" stroke="rgba(6,182,212,0.2)" stroke-width="0.5"/>
</svg>
